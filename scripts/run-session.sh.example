#!/bin/bash
# Autonomous-mode session runner — triggered by cron on a schedule.
# Runs a Claude Code session if memory/next-run-at indicates it's time.
# The agent writes next-run-at at the end of each session to schedule
# the next run.
#
# Setup:
#   1. cp scripts/run-session.sh.example scripts/run-session.sh
#   2. Edit REPO_DIR below to point at your actual clone path.
#   3. chmod +x scripts/run-session.sh
#   4. Add to crontab (every 15 min, adjust as needed):
#        */15 * * * * /path/to/repo/scripts/run-session.sh
#   5. Make sure session-prompt.md exists at the repo root with a
#      high-level directive for the agent (see SETUP.md).

set -e

# ---- Configure these for your environment ----
REPO_DIR="$HOME/kamigotchi-context"
LOG_FILE="$HOME/kamigotchi-session.log"
LOCK_FILE="/tmp/kamigotchi-session.lock"
SESSION_TIMEOUT="30m"      # hard cap per session
DEFAULT_INTERVAL_SECS=21600  # 6 hours fallback when agent forgets to schedule

# ---- Implementation ----
NEXT_RUN_FILE="$REPO_DIR/memory/next-run-at"

# Prevent overlapping sessions
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
    exit 0
fi

# Check schedule — skip if not yet time
if [ -f "$NEXT_RUN_FILE" ]; then
    scheduled=$(cat "$NEXT_RUN_FILE" | tr -d '[:space:]')
    now=$(date +%s)
    if [ -n "$scheduled" ] && [ "$now" -lt "$scheduled" ]; then
        exit 0
    fi
fi

# Run session
cd "$REPO_DIR"
{
    echo ""
    echo "=========================================="
    echo "=== Session started: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    echo "=========================================="

    timeout "$SESSION_TIMEOUT" claude \
        -p "$(cat session-prompt.md)" \
        --max-turns 200 \
        --model claude-opus-4-7 \
        --dangerously-skip-permissions \
        2>&1

    echo ""
    echo "=== Session ended: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
    echo ""
} >> "$LOG_FILE"

# Fallback: if agent didn't set next-run-at, default to DEFAULT_INTERVAL_SECS from now
need_default=0
if [ ! -f "$NEXT_RUN_FILE" ]; then
    need_default=1
else
    scheduled=$(cat "$NEXT_RUN_FILE" | tr -d '[:space:]')
    if [ -z "$scheduled" ] || [ "$(date +%s)" -ge "$scheduled" ]; then
        need_default=1
    fi
fi
if [ "$need_default" -eq 1 ]; then
    echo $(($(date +%s) + DEFAULT_INTERVAL_SECS)) > "$NEXT_RUN_FILE"
fi
