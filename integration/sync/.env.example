# Yominet RPC endpoint
RPC_HTTP_URL=https://jsonrpc-yominet-1.anvil.asia-southeast.initia.xyz

# Kamigotchi World contract address
STORE_ADDRESS=0x2729174c265dbBd8416C6449E0E813E88f43D0E7

# Chain ID (for REST API queries)
CHAIN_ID=428962654539583

# Block tag to follow — use "latest" for Yominet
FOLLOW_BLOCK_TAG=latest

# Starting block — set to World deployment block for faster initial sync
# Leave at 0 to sync from genesis (slower but complete)
START_BLOCK=0

# Blocks per eth_getLogs call
MAX_BLOCK_RANGE=1000

# Polling interval in milliseconds
POLLING_INTERVAL=1000

# PostgreSQL credentials
POSTGRES_USER=kamigotchi
POSTGRES_PASSWORD=kamigotchi
POSTGRES_DB=kamigotchi
POSTGRES_PORT=5432

# Indexer API port
INDEXER_PORT=3001
